{
	"$schema": "https://opencode.ai/config.json",
	// Dinamyc context pruning
	"plugin": [
		"@tarquinen/opencode-dcp@latest",
		"opencode-froggy",
		"@bastiangx/opencode-unmoji",

	],
	"mcp": {
		"context7": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@upstash/context7-mcp",
				"--api-key",
				"ctx7sk-d397cdc8-1682-415b-801c-2cf4b97af827"
			]
		},
		"Astro docs": {
			"type": "remote",
			"url": "https://mcp.docs.astro.build/mcp",
			"enabled": true
		},
		"pdf-reader": {
			"command": [
				"npx",
				"@sylphx/pdf-reader-mcp"
			],
			"type": "local"
		},
		"chrome-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"chrome-devtools-mcp@latest"
			]
		},
		"firefox-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"firefox-devtools-mcp@latest",
				"--headless",
				"--viewport",
				"1280x720"
			]
		}
	}
}

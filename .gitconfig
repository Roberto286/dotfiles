[user]
	email = roberto.saliola96@gmail.com
	name = Roberto Saliola
[pull]
	rebase = true
[core]
	autocrlf = input
	editor = nvim
[push]
	autoSetupRemote = true
[includeIf "gitdir:~/code/personal/"]
    path = ~/.gitconfig-personal
[init]
	defaultBranch = main
[includeIf "gitdir:~/.dotfiles/"]
	path = ~/.gitconfig-dotfiles
